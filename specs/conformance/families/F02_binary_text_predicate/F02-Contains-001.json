{
    "id":  "F02-Contains-001",
    "rule":  "R-TXT-PRED",
    "data":  {
                 "sheet":  "S",
                 "rows":  [
                              [
                                  "S"
                              ],
                              [
                                  "Hello"
                              ],
                              [
                                  "World"
                              ]
                          ],
                 "source":  "tx.xlsx"
             },
    "formula":  "let\r\n    Source = Excel.Workbook(File.Contents(\"x\")),\r\n    Sheet1 = Source{[Item=\"S\",Kind=\"Sheet\"]}[Data],\r\n    Result = Table.SelectRows(Sheet1, each Text.Contains([S], \"ell\"))\r\nin\r\n    Result",
    "description":  "Text.Contains as filter predicate",
    "expect_ok":  {
                      "rows":  [
                                   [
                                       "Hello"
                                   ]
                               ],
                      "row_count":  1
                  }
}