{
    "id":  "F01-TextUpper-001",
    "rule":  "R-TXT-01",
    "data":  {
                 "sheet":  "S",
                 "rows":  [
                              [
                                  "S"
                              ],
                              [
                                  "Hello"
                              ],
                              [
                                  "World"
                              ]
                          ],
                 "source":  "tx.xlsx"
             },
    "formula":  "let\r\n    Source = Excel.Workbook(File.Contents(\"x\")),\r\n    Sheet1 = Source{[Item=\"S\",Kind=\"Sheet\"]}[Data],\r\n    Result = Table.AddColumn(Sheet1, \"U\", each Text.Upper([S]))\r\nin\r\n    Result",
    "description":  "Text.Upper uppercases each value",
    "expect_ok":  {
                      "columns":  [
                                      "S",
                                      "U"
                                  ],
                      "row_count":  2
                  }
}