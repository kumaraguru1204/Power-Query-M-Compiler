                                  "60000"
                              ],
                              [
                                  "Dora",
                                  "IT",
                                  "40000"
                              ]
                          ],
                 "source":  "tx.xlsx"
             },
    "formula":  "let\r\n    Source = Excel.Workbook(File.Contents(\"x\")),\r\n    Sheet1 = Source{[Item=\"S\",Kind=\"Sheet\"]}[Data],\r\n    Result = Table.Distinct(Sheet1, {\"Dept\"})\r\nin\r\n    Result",
    "description":  "Distinct on a single column drops duplicates",
    "expect_ok":  {
                      "row_count":  2
                  }
