{
    "id":  "F09-AddColumn-001",
    "rule":  "R-TBL-COL-02",
    "data":  {
                 "sheet":  "S",
                 "rows":  [
                              [
                                  "A"
                              ],
                              [
                                  "1"
                              ],
                              [
                                  "2"
                              ]
                          ],
                 "source":  "a.xlsx"
             },
    "formula":  "let\r\n    Source = Excel.Workbook(File.Contents(\"x\")),\r\n    Sheet1 = Source{[Item=\"S\",Kind=\"Sheet\"]}[Data],\r\n    Result = Table.AddColumn(Sheet1, \"B\", each [A] * 10)\r\nin\r\n    Result",
    "description":  "AddColumn appends a new column at the right",
    "expect_ok":  {
                      "columns":  [
                                      "A",
                                      "B"
                                  ],
                      "row_count":  2
                  }
}